include README.md LICENSE CHANGELOG.md AGENTS.md action.yml
recursive-include docs *.md
recursive-include examples *.md *.yaml *.csv
recursive-include scripts *.py
recursive-include skills *.md *.yaml
recursive-include tests *.py
recursive-include .github *.md *.yml *.yaml
prune examples/demo/generated
prune artifacts
global-exclude *.py[cod] .env .coverage
